ant;background-color: #FFFFFF !important;padding-bottom: 5px !important;padding-top: 5px !important;padding-left: 10px !important;padding-right: 10px !important;max-height: 70% !important;}.cmpboxCustomChoices{max-width: auto !important;margin-top: 15px !important;margin-right: 15px !important;margin-bottom: 15px !important;margin-left: 15px !important;max-height: auto !important;}.cmpboxbtncustom{background-color: #5E463A !important;border-top-width: 2px !important;border-right-width: 2px !important;border-bottom-width: 2px !important;border-left-width: 2px !important;border-top-color: #A47A65 !important;border-right-color: #A47A65 !important;border-bottom-color: #A47A65 !important;border-left-color: #A47A65 !important;border-radius: 5px !important;}.cmpboxbtnno{font-family: \"Fira Sans\" !important;background-color: #557D1E !important;border-top-width: 0px !important;border-right-width: 0px !important;border-bottom-width: 0px !important;border-left-width: 0px !important;border-top-color: #CFDCBE !important;border-right-color: #CFDCBE !important;border-bottom-color: #CFDCBE !important;border-left-color: #CFDCBE !important;border-radius: 30px !important;font-size: 18px !important;box-shadow: none !important;font-weight: normal !important;}.cmpboxbtns{margin-bottom: 0px !important;padding-bottom: 0px !important;}.cmpboxbtnsave{background-color: #546E39 !important;border-top-width: 2px !important;border-right-width: 2px !important;border-bottom-width: 2px !important;border-left-width: 2px !important;border-top-color: #CFDCBE !important;border-right-color: #CFDCBE !important;border-bottom-color: #CFDCBE !important;border-left-color: #CFDCBE !important;border-radius: 5px !important;}.cmpboxbtnscustomchoices{margin-top: 0px !important;padding-top: 0px !important;padding-left: 10px !important;}.cmpboxbtnyes{background-color: #557D1E !important;border-top-width: 0px !important;border-right-width: 0px !important;border-bottom-width: 0px !important;border-left-width: 0px !important;border-top-color: #CFDCBE !important;border-right-color: #CFDCBE !important;border-bottom-color: #CFDCBE !important;border-left-color: #CFDCBE !important;border-radius: 30px !important;font-style: normal !important;font-weight: normal !important;width: 200px !important;font-size: 18px !important;text-decoration: none !important;font-family: \"Fira Sans\" !important;box-shadow: none !important;}.cmpboxcontent{max-width: auto !important;overflow-x: auto !important;overflow-y: auto !important;box-shadow: none !important;margin-top: 0px !important;max-height: auto !important;}.cmpboxhl{text-align: center !important;font-family: \"Fira Sans\" !important;font-size: 15px !important;color: #5A5A5A !important;}.cmpboxinner{overflow-x: auto !important;overflow-y: auto !important;}.cmpboxnaviitemactive{background-color: #5E463A !important;color: #FFFFFF !important;}.cmpboxtxt{font-style: normal !important;font-size: 13px !important;font-family: \"Fira Sans\" !important;color: #5A5A5A !important;padding-bottom: 10px !important;}.cmpboxwelcomeprps{padding-top: 2px !important;padding-bottom: 0px !important;}.cmplink{color: #63A90B !important;font-size: 12px !important;font-style: normal !important;}.cmpmore{color: #63A90B !important;font-size: 9px !important;padding-top: 10px !important;font-family: \"Fira Sans\" !important;}.cmpmorelink{font-family: \"Fira Sans\" !important;color: #557D1E !important;text-decoration: underline !important;}.cmpwelcomeprpstxt{font-size: 13px !important;font-weight: normal !important;font-style: normal !important;text-decoration: none !important;text-align: justify !important;font-family: \"Fira Sans\" !important;color: #5A5A5A !important;}","foundLang":"EN","seperateDomain":false,"strWebsite":"Travian Games GmbH","verGVLv3":150,"verGVLvca2":177,"pubcc":"DE","compresscookie":1,"storecookie":1,"storels":1,"showCompany":0,"boolWCAG":1,"boolEnableGatekeeper":0,"boolTransitionEnabled":1,"boolShowLayerPolicyPage":0,"strDontShowLayer":"","boolShowTvIntegrationLink":0,"customLang":[{"strLang":"DE","strType":"btn_more","strText":"Datenschutz","intTextVersion":87362},{"strLang":"DE","strType":"btn_save","strText":"Speichern","intTextVersion":87361},{"strLang":"DE","strType":"companyinfo_mail","strText":"E-Mail","intTextVersion":87361},{"strLang":"DE","strType":"cookietype_6","strText":"Soziale Medien","intTextVersion":87361},{"strLang":"DE","strType":"hl","strText":"Einwilligung zur Datenverarbeitung","intTextVersion":87361},{"strLang":"DE","strType":"txt","strText":"<p>Mit Ihrer Einwilligung erfassen wir bestimmte Informationen zu Ihrem Ger\u00e4t, Ihrer IP-Adresse, Ihrer Nutzung und Werbekennungen.&nbsp;<\/p><p><\/p><p>Dadurch k\u00f6nnen wir Ihnen relevantere Anzeigen zeigen und Ihr App-Erlebnis insgesamt verbessern.<\/p>","intTextVersion":134743},{"strLang":"DE","strType":"txt_custom","strText":"Auf dieser Seite k\u00f6nnen Sie Informationen zu den Anbietern erfahren, die personenbezogene Daten auf unserer Webseite verarbeiten.","intTextVersion":87361},{"strLang":"EN","strType":"btn_more","strText":"Privacy","intTextVersion":87361},{"strLang":"EN","strType":"companyinfo_mail","strText":"E-mail","intTextVersion":87360},{"strLang":"EN","strType":"txt","strText":"<p>With your consent, we collect certain information concerning your device, IP address, usage and advertising identifiers.<\/p><p><\/p><p>This helps us to show you more relevant ads and improves your overall app experience.<\/p>","intTextVersion":134744},{"strLang":"DE","strType":"txt_att","strText":"Wir erfassen bestimmte Informationen zu Ihrem Ger\u00e4t, Ihrer IP-Adresse und Ihrer Nutzung, um die Leistung und Funktionalit\u00e4t der App zu analysieren.","intTextVersion":87361},{"strLang":"EN","strType":"txt_att","strText":"We collect certain information concerning your device, IP address, and usage to analyze the performance and the functionality of the app.","intTextVersion":87360},{"strLang":"ES","strType":"txt_att","strText":"Recopilamos cierta informaci\u00f3n sobre su dispositivo, direcci\u00f3n IP y uso para analizar el rendimiento y la funcionalidad de la aplicaci\u00f3n. Sus datos pueden ser compartidos y procesados por hasta [link=vendors][vendorcount] proveedores externos[\/link] para estos fines.","intTextVersion":87264},{"strLang":"FR","strType":"txt_att","strText":"Nous collectons certaines informations concernant votre appareil, votre adresse IP et votre utilisation pour analyser les performances et les fonctionnalit\u00e9s de l&#39;application. Vos donn\u00e9es peuvent \u00eatre partag\u00e9es et trait\u00e9es par jusqu&#39;\u00e0 [link=vendors][vendorcount] fournisseurs tiers[\/link] \u00e0 ces fins.","intTextVersion":87265},{"strLang":"IT","strType":"txt_att","strText":"Raccogliamo alcune informazioni relative al tuo dispositivo, indirizzo IP e utilizzo per analizzare le prestazioni e la funzionalit\u00e0 dell&#39;app. I tuoi dati potrebbero essere condivisi ed elaborati da un massimo di [link=vendors][vendorcount]fornitori di terze parti[\/link] per questi scopi.","intTextVersion":87266},{"strLang":"SV","strType":"txt_att","strText":"Vi samlar in viss information om din enhet, IP-adress och anv\u00e4ndning f\u00f6r att analysera appens prestanda och funktionalitet. Dina uppgifter kan delas med och behandlas av upp till [link=vendors][vendorcount] tredjepartsleverant\u00f6rer[\/link] f\u00f6r dessa \u00e4ndam\u00e5l.","intTextVersion":87267},{"strLang":"BG","strType":"txt_att","strText":"\u041d\u0438\u0435 \u0441\u044a\u0431\u0438\u0440\u0430\u043c\u0435 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0430 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f \u043e\u0442\u043d\u043e\u0441\u043d\u043e \u0432\u0430\u0448\u0435\u0442\u043e \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u043e, IP \u0430\u0434\u0440\u0435\u0441 \u0438 \u0443\u043f\u043e\u0442\u0440\u0435\u0431\u0430, \u0437\u0430 \u0434\u0430 \u0430\u043d\u0430\u043b\u0438\u0437\u0438\u0440\u0430\u043c\u0435 \u0435\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0442\u0430 \u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u043d\u043e\u0441\u0442\u0442\u0430 \u043d\u0430 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435\u0442\u043e. \u0412\u0430\u0448\u0438\u0442\u0435 \u0434\u0430\u043d\u043d\u0438 \u043c\u043e\u0433\u0430\u0442 \u0434\u0430 \u0431\u044a\u0434\u0430\u0442 \u0441\u043f\u043e\u0434\u0435\u043b\u044f\u043d\u0438 \u0438 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u0432\u0430\u043d\u0438 \u043e\u0442 \u0434\u043e [link=vendors][vendorcount] \u0434\u043e\u0441\u0442\u0430\u0432\u0447\u0438\u0446\u0438 \u0442\u0440\u0435\u0442\u0438 \u0441\u0442\u0440\u0430\u043d\u0438[\/link] \u0437\u0430 \u0442\u0435\u0437\u0438 \u0446\u0435\u043b\u0438.","intTextVersion":87268},{"strLang":"CS","strType":"txt_att","strText":"Shroma\u017e\u010fujeme ur\u010dit\u00e9 informace t\u00fdkaj\u00edc\u00ed se va\u0161eho za\u0159\u00edzen\u00ed, IP adresy a pou\u017eit\u00ed za \u00fa\u010delem anal\u00fdzy v\u00fdkonu a funk\u010dnosti aplikace. Va\u0161e \u00fadaje mohou b\u00fdt pro tyto \u00fa\u010dely sd\u00edleny a zpracov\u00e1v\u00e1ny a\u017e [link=vendors][vendorcount] poskytovateli t\u0159et\u00edch stran[\/link].","intTextVersion":87269},{"strLang":"DA","strType":"txt_att","strText":"Vi indsamler visse oplysninger om din enhed, IP-adresse og brug for at analysere appens ydeevne og funktionalitet. Dine data kan blive delt med og behandlet af op til [link=vendors][vendorcount] tredjepartsudbydere[\/link] til disse form\u00e5l.","intTextVersion":87270},{"strLang":"EL","strType":"txt_att","strText":"\u03a3\u03c5\u03bb\u03bb\u03ad\u03b3\u03bf\u03c5\u03bc\u03b5 \u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03b5\u03c2 \u03c0\u03bb\u03b7\u03c1\u03bf\u03c6\u03bf\u03c1\u03af\u03b5\u03c2 \u03c3\u03c7\u03b5\u03c4\u03b9\u03ba\u03ac \u03bc\u03b5 \u03c4\u03b7 \u03c3\u03c5\u03c3\u03ba\u03b5\u03c5\u03ae \u03c3\u03b1\u03c2, \u03c4\u03b7 \u03b4\u03b9\u03b5\u03cd\u03b8\u03c5\u03bd\u03c3\u03b7 IP \u03ba\u03b1\u03b9 \u03c4\u03b7 \u03c7\u03c1\u03ae\u03c3\u03b7 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b1\u03bd\u03b1\u03bb\u03cd\u03c3\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b7\u03bd \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03c4\u03b7 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03b7\u03c2 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae\u03c2. \u03a4\u03b1 \u03b4\u03b5\u03b4\u03bf\u03bc\u03ad\u03bd\u03b1 \u03c3\u03b1\u03c2 \u03b5\u03bd\u03b4\u03ad\u03c7\u03b5\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03ba\u03bf\u03b9\u03bd\u03bf\u03c0\u03bf\u03b9\u03b7\u03b8\u03bf\u03cd\u03bd \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03c5\u03c0\u03bf\u03b2\u03bb\u03b7\u03b8\u03bf\u03cd\u03bd \u03c3\u03b5 \u03b5\u03c0\u03b5\u03be\u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1 \u03b1\u03c0\u03cc \u03ad\u03c9\u03c2 \u03ba\u03b1\u03b9 [link=vendors][vendorcount] \u03c4\u03c1\u03af\u03c4\u03bf\u03c5\u03c2 \u03c0\u03b1\u03c1\u03cc\u03c7\u03bf\u03c5\u03c2[\/link] \u03b3\u03b9\u03b1 \u03b1\u03c5\u03c4\u03bf\u03cd\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03c3\u03ba\u03bf\u03c0\u03bf\u03cd\u03c2.","intTextVersion":87271},{"strLang":"ET","strType":"txt_att","strText":"Kogume teie seadme, IP-aadressi ja kasutuse kohta teatud teavet, et anal\u00fc\u00fcsida rakenduse j\u00f5udlust ja funktsionaalsust. Nendel eesm\u00e4rkidel v\u00f5ib teie andmeid jagada kuni [link=vendors][vendorcount] kolmandast osapoolest teenusepakkujaga[\/link] ja neid t\u00f6\u00f6delda.","intTextVersion":87272},{"strLang":"FI","strType":"txt_att","strText":"Ker\u00e4\u00e4mme tiettyj\u00e4 tietoja laitteestasi, IP-osoitteestasi ja k\u00e4yt\u00f6st\u00e4si analysoidaksemme sovelluksen suorituskyky\u00e4 ja toimivuutta. Tietosi voidaan jakaa ja k\u00e4sitell\u00e4 enint\u00e4\u00e4n [link=vendors][vendorcount] kolmannen osapuolen palveluntarjoajan[\/link] kanssa n\u00e4it\u00e4 tarkoituksia varten.","intTextVersion":87273},{"strLang":"GA","strType":"txt_att","strText":"Bail\u00edmid faisn\u00e9is \u00e1irithe maidir le do ghl\u00e9as, seoladh IP, agus \u00fas\u00e1id chun anail\u00eds a dh\u00e9anamh ar fheidhm\u00edocht agus ar fheidhmi\u00falacht na haipe. Is f\u00e9idir do shonra\u00ed a roinnt le agus a phr\u00f3ise\u00e1il ag suas le [link=vendors][vendorcount] sol\u00e1thraithe tr\u00ed\u00fa p\u00e1irt\u00ed[\/link] chun na gcr\u00edoch seo.","intTextVersion":87274},{"strLang":"HR","strType":"txt_att","strText":"Prikupljamo odre\u0111ene podatke koji se odnose na va\u0161 ure\u0111aj, IP adresu i upotrebu kako bismo analizirali izvedbu i funkcionalnost aplikacije. Va\u0161e podatke mogu dijeliti i obra\u0111ivati najvi\u0161e [link=vendors][vendorcount] pru\u017eatelji tre\u0107ih strana[\/link] u ove svrhe.","intTextVersion":87275},{"strLang":"HU","strType":"txt_att","strText":"Az alkalmaz\u00e1s teljes\u00edtm\u00e9ny\u00e9nek \u00e9s funkcionalit\u00e1s\u00e1nak elemz\u00e9s\u00e9hez bizonyos inform\u00e1ci\u00f3kat gy\u0171jt\u00fcnk az eszk\u00f6z\u00e9re, IP-c\u00edm\u00e9re \u00e9s haszn\u00e1lat\u00e1ra vonatkoz\u00f3an. Adatait legfeljebb [link=vendors][vendorcount] harmadik f\u00e9l szolg\u00e1ltat\u00f3val[\/link] oszthatja meg \u00e9s dolgozhatja fel ilyen c\u00e9lokra.","intTextVersion":87276},{"strLang":"LT","strType":"txt_att","strText":"Mes renkame tam tikr\u0105 informacij\u0105 apie j\u016bs\u0173 \u012frengin\u012f, IP adres\u0105 ir naudojim\u0105, kad gal\u0117tume analizuoti programos veikim\u0105 ir funkcionalum\u0105. \u0160iais tikslais j\u016bs\u0173 duomenys gali b\u016bti bendrinami ir tvarkomi iki [link=vendors][vendorcount] tre\u010di\u0173j\u0173 \u0161ali\u0173 teik\u0117j\u0173[\/link].","intTextVersion":87277},{"strLang":"LV","strType":"txt_att","strText":"M\u0113s apkopojam noteiktu inform\u0101ciju par j\u016bsu ier\u012bci, IP adresi un lietojumu, lai analiz\u0113tu lietotnes veiktsp\u0113ju un funkcionalit\u0101ti. \u0160iem nol\u016bkiem j\u016bsu datus var kop\u012bgot un apstr\u0101d\u0101t l\u012bdz pat [link=vendors][vendorcount] tre\u0161\u0101s puses pakalpojumu sniedz\u0113jiem[\/link].","intTextVersion":87278},{"strLang":"MT","strType":"txt_att","strText":"A\u0127na ni\u0121bru \u010berta informazzjoni dwar it-tag\u0127mir tieg\u0127ek, l-indirizz IP, u l-u\u017cu biex nanalizzaw il-prestazzjoni u l-funzjonalit\u00e0 tal-app. Id-dejta tieg\u0127ek tista&#39; ti\u0121i kondivi\u017ca u ppro\u010bessata minn sa [link=vendors][vendorcount] fornituri ta&#39; partijiet terzi[\/link] g\u0127al dawn l-g\u0127anijiet.","intTextVersion":87279},{"strLang":"NL","strType":"txt_att","strText":"We verzamelen bepaalde informatie over uw apparaat, IP-adres en gebruik om de prestaties en functionaliteit van de app te analyseren. Voor deze doeleinden kunnen uw gegevens worden gedeeld met en verwerkt door maximaal [link=vendors][vendorcount] externe providers[\/link].","intTextVersion":87280},{"strLang":"NO","strType":"txt_att","strText":"Vi samler inn viss informasjon om din enhet, IP-adresse og bruk for \u00e5 analysere ytelsen og funksjonaliteten til appen. Dataene dine kan bli delt med og behandlet av opptil [link=vendors][vendorcount] tredjepartsleverand\u00f8rer[\/link] for disse form\u00e5lene.","intTextVersion":87281},{"strLang":"PL","strType":"txt_att","strText":"Zbieramy pewne informacje dotycz\u0105ce Twojego urz\u0105dzenia, adresu IP i sposobu u\u017cytkowania, aby analizowa\u0107 wydajno\u015b\u0107 i funkcjonalno\u015b\u0107 aplikacji. Twoje dane mog\u0105 by\u0107 udost\u0119pniane i przetwarzane maksymalnie przez [link=vendors][vendorcount] zewn\u0119trznych dostawc\u00f3w[\/link] w tych celach.","intTextVersion":87282},{"strLang":"PT","strType":"txt_att","strText":"Coletamos certas informa\u00e7\u00f5es sobre seu dispositivo, endere\u00e7o IP e uso para analisar o desempenho e a funcionalidade do aplicativo. Seus dados podem ser compartilhados e processados por at\u00e9 [link=vendors][vendorcount] fornecedores terceirizados[\/link] para esses fins.","intTextVersion":87283},{"strLang":"RO","strType":"txt_att","strText":"Colect\u0103m anumite informa\u021bii referitoare la dispozitivul dvs., adresa IP \u0219i utilizarea pentru a analiza performan\u021ba \u0219i func\u021bionalitatea aplica\u021biei. Datele dvs. pot fi partajate \u0219i procesate de p\u00e2n\u0103 la [link=vendors][vendorcount] furnizori ter\u021bi[\/link] \u00een aceste scopuri.","intTextVersion":87284},{"strLang":"SK","strType":"txt_att","strText":"Zhroma\u017e\u010fujeme ur\u010dit\u00e9 inform\u00e1cie o va\u0161om zariaden\u00ed, IP adrese a pou\u017e\u00edvan\u00ed, aby sme analyzovali v\u00fdkon a funk\u010dnos\u0165 aplik\u00e1cie. Va\u0161e \u00fadaje m\u00f4\u017eu by\u0165 na tieto \u00fa\u010dely zdie\u013ean\u00e9 a spracov\u00e1van\u00e9 a\u017e [link=vendors][vendorcount] poskytovate\u013emi tret\u00edch str\u00e1n[\/link].","intTextVersion":87285},{"strLang":"SL","strType":"txt_att","strText":"Zbiramo dolo\u010dene podatke v zvezi z va\u0161o napravo, naslovom IP in uporabo, da analiziramo delovanje in funkcionalnost aplikacije. Za te namene se lahko va\u0161i podatki delijo z najve\u010d [link=vendors][vendorcount] tretjimi ponudniki[\/link] in jih obdelujejo.","intTextVersion":87286},{"strLang":"RU","strType":"txt_att","strText":"\u041c\u044b \u0441\u043e\u0431\u0438\u0440\u0430\u0435\u043c \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u043d\u0443\u044e \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e \u043e \u0432\u0430\u0448\u0435\u043c \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0435, IP-\u0430\u0434\u0440\u0435\u0441\u0435 \u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0438 \u0434\u043b\u044f \u0430\u043d\u0430\u043b\u0438\u0437\u0430 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f. \u0414\u043b\u044f \u044d\u0442\u0438\u0445 \u0446\u0435\u043b\u0435\u0439 \u0432\u0430\u0448\u0438 \u0434\u0430\u043d\u043d\u044b\u0435 \u043c\u043e\u0433\u0443\u0442 \u043f\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u0438 \u043e\u0431\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0435 \u0431\u043e\u043b\u0435\u0435 \u0447\u0435\u043c [link=vendors][vendorcount] \u0441\u0442\u043e\u0440\u043e\u043d\u043d\u0438\u043c\u0438 \u043f\u043e\u0441\u0442\u0430\u0432\u0449\u0438\u043a\u0430\u043c\u0438[\/link].","intTextVersion":87287},{"strLang":"UK","strType":"txt_att","strText":"\u041c\u0438 \u0437\u0431\u0438\u0440\u0430\u0454\u043c\u043e \u043f\u0435\u0432\u043d\u0443 \u0456\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0456\u044e \u043f\u0440\u043e \u0432\u0430\u0448 \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439, IP-\u0430\u0434\u0440\u0435\u0441\u0443 \u0442\u0430 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0434\u043b\u044f \u0430\u043d\u0430\u043b\u0456\u0437\u0443 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0456 \u0442\u0430 \u0444\u0443\u043d\u043a\u0446\u0456\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0456 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u0438. \u0414\u043b\u044f \u0446\u0438\u0445 \u0446\u0456\u043b\u0435\u0439 \u0432\u0430\u0448\u0456 \u0434\u0430\u043d\u0456 \u043c\u043e\u0436\u0443\u0442\u044c \u043d\u0430\u0434\u0430\u0432\u0430\u0442\u0438\u0441\u044f \u0442\u0430 \u043e\u0431\u0440\u043e\u0431\u043b\u044f\u0442\u0438\u0441\u044f [link=vendors][vendorcount] \u0441\u0442\u043e\u0440\u043e\u043d\u043d\u0456\u043c\u0438 \u043f\u043e\u0441\u0442\u0430\u0447\u0430\u043b\u044c\u043d\u0438\u043a\u0430\u043c\u0438[\/link].","intTextVersion":87288},{"strLang":"TR","strType":"txt_att","strText":"Uygulaman\u0131n performans\u0131n\u0131 ve i\u015flevselli\u011fini analiz etmek i\u00e7in cihaz\u0131n\u0131z, IP adresiniz ve kullan\u0131m\u0131n\u0131zla ilgili belirli bilgileri topluyoruz. Verileriniz bu ama\u00e7lar do\u011frultusunda en fazla [link=vendors][vendorcount] \u00fc\u00e7\u00fcnc\u00fc taraf sa\u011flay\u0131c\u0131[\/link] ile payla\u015f\u0131labilir ve onlar taraf\u0131ndan i\u015flenebilir.","intTextVersion":87289},{"strLang":"ZH","strType":"txt_att","strText":"\u6211\u4eec\u6536\u96c6\u6709\u5173\u60a8\u7684\u8bbe\u5907\u3001IP \u5730\u5740\u548c\u4f7f\u7528\u60c5\u51b5\u7684\u67d0\u4e9b\u4fe1\u606f\uff0c\u4ee5\u5206\u6790\u5e94\u7528\u7a0b\u5e8f\u7684\u6027\u80fd\u548c\u529f\u80fd\u3002\u51fa\u4e8e\u8fd9\u4e9b\u76ee\u7684\uff0c\u60a8\u7684\u6570\u636e\u53ef\u80fd\u4f1a\u4e0e\u6700\u591a [link=vendors][vendorcount] \u4e2a\u7b2c\u4e09\u65b9\u63d0\u4f9b\u5546[\/link]\u5171\u4eab\u548c\u5904\u7406\u3002","intTextVersion":87290},{"strLang":"SR","strType":"txt_att","strText":"\u041f\u0440\u0438\u043a\u0443\u043f\u0459\u0430\u043c\u043e \u043e\u0434\u0440\u0435\u0452\u0435\u043d\u0435 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0458\u0435 \u0443 \u0432\u0435\u0437\u0438 \u0441\u0430 \u0432\u0430\u0448\u0438\u043c \u0443\u0440\u0435\u0452\u0430\u0458\u0435\u043c, \u0418\u041f \u0430\u0434\u0440\u0435\u0441\u043e\u043c \u0438 \u0443\u043f\u043e\u0442\u0440\u0435\u0431\u043e\u043c \u0434\u0430 \u0431\u0438\u0441\u043c\u043e \u0430\u043d\u0430\u043b\u0438\u0437\u0438\u0440\u0430\u043b\u0438 \u043f\u0435\u0440\u0444\u043e\u0440\u043c\u0430\u043d\u0441\u0435 \u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u043d\u043e\u0441\u0442 \u0430\u043f\u043b\u0438\u043a\u0430\u0446\u0438\u0458\u0435. \u0412\u0430\u0448\u0435 \u043f\u043e\u0434\u0430\u0442\u043a\u0435 \u043c\u043e\u0436\u0435 \u0434\u0430 \u0434\u0435\u043b\u0438 \u0438 \u043e\u0431\u0440\u0430\u0452\u0443\u0458\u0435 \u043d\u0430\u0458\u0432\u0438\u0448\u0435 [\u043b\u0438\u043d\u043a=\u0432\u0435\u043d\u0434\u043e\u0440\u0441][\u0432\u0435\u043d\u0434\u043e\u0440\u0446\u043e\u0443\u043d\u0442] \u043d\u0435\u0437\u0430\u0432\u0438\u0441\u043d\u0438\u0445 \u0434\u043e\u0431\u0430\u0432\u0459\u0430\u0447\u0430[\/\u043b\u0438\u043d\u043a] \u0443 \u043e\u0432\u0435 \u0441\u0432\u0440\u0445\u0435.","intTextVersion":87291},{"strLang":"AR","strType":"txt_att","strText":"\u0646\u0642\u0648\u0645 \u0628\u062c\u0645\u0639 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0645\u0639\u064a\u0646\u0629 \u062a\u062a\u0639\u0644\u0642 \u0628\u062c\u0647\u0627\u0632\u0643 \u0648\u0639\u0646\u0648\u0627\u0646 IP \u0648\u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0643 \u0644\u062a\u062d\u0644\u064a\u0644 \u0623\u062f\u0627\u0621 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0648\u0648\u0638\u0627\u0626\u0641\u0647. \u0642\u062f \u062a\u062a\u0645 \u0645\u0634\u0627\u0631\u0643\u0629 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0648\u0645\u0639\u0627\u0644\u062c\u062a\u0647\u0627 \u0628\u0648\u0627\u0633\u0637\u0629 \u0645\u0627 \u064a\u0635\u0644 \u0625\u0644\u0649 [link=vendors][vendorcount] \u0645\u0646 \u0645\u0648\u0641\u0631\u064a \u0627\u0644\u0637\u0631\u0641 \u0627\u0644\u062b\u0627\u0644\u062b[\/link] \u0644\u0647\u0630\u0647 \u0627\u0644\u0623\u063a\u0631\u0627\u0636.","intTextVersion":87292},{"strLang":"BS","strType":"txt_att","strText":"Prikupljamo odre\u0111ene informacije o va\u0161em ure\u0111aju, IP adresi i kori\u0161tenju kako bismo analizirali performanse i funkcionalnost aplikacije. Va\u0161e podatke mo\u017ee dijeliti i obra\u0111ivati najvi\u0161e [link=vendors][vendorcount] provajdera tre\u0107ih strana[\/link] u ove svrhe.","intTextVersion":87293},{"strLang":"ES","strType":"txt","strText":"Con su consentimiento, recopilamos cierta informaci\u00f3n sobre su dispositivo, direcci\u00f3n IP, uso e identificadores de publicidad. Esto nos ayuda a mostrarle anuncios m\u00e1s relevantes y mejora su experiencia general con la aplicaci\u00f3n.","intTextVersion":87330},{"strLang":"FR","strType":"txt","strText":"Avec votre consentement, nous collectons certaines informations concernant votre appareil, votre adresse IP, vos identifiants d&#39;utilisation et publicitaires. Cela nous aide \u00e0 vous montrer des publicit\u00e9s plus pertinentes et \u00e0 am\u00e9liorer votre exp\u00e9rience globale de l&#39;application.","intTextVersion":87331},{"strLang":"IT","strType":"txt","strText":"Con il tuo consenso, raccogliamo alcune informazioni relative al tuo dispositivo, indirizzo IP, utilizzo e identificatori pubblicitari. Questo ci aiuta a mostrarti annunci pi\u00f9 pertinenti e a migliorare la tua esperienza complessiva con l&#39;app.","intTextVersion":87332},{"strLang":"SV","strType":"txt","strText":"Med ditt samtycke samlar vi in viss information om din enhet, IP-adress, anv\u00e4ndning och reklamidentifierare. Detta hj\u00e4lper oss att visa dig mer relevanta annonser och f\u00f6rb\u00e4ttrar din \u00f6vergripande appupplevelse.","intTextVersion":87333},{"strLang":"BG","strType":"txt","strText":"\u0421 \u0432\u0430\u0448\u0435\u0442\u043e \u0441\u044a\u0433\u043b\u0430\u0441\u0438\u0435 \u043d\u0438\u0435 \u0441\u044a\u0431\u0438\u0440\u0430\u043c\u0435 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0430 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f \u043e\u0442\u043d\u043e\u0441\u043d\u043e \u0432\u0430\u0448\u0435\u0442\u043e \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u043e, IP \u0430\u0434\u0440\u0435\u0441, \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0435 \u0438 \u0440\u0435\u043a\u043b\u0430\u043c\u043d\u0438 \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u0438. \u0422\u043e\u0432\u0430 \u043d\u0438 \u043f\u043e\u043c\u0430\u0433\u0430 \u0434\u0430 \u0432\u0438 \u043f\u043e\u043a\u0430\u0437\u0432\u0430\u043c\u0435 \u043f\u043e-\u043f\u043e\u0434\u0445\u043e\u0434\u044f\u0449\u0438 \u0440\u0435\u043a\u043b\u0430\u043c\u0438 \u0438 \u043f\u043e\u0434\u043e\u0431\u0440\u044f\u0432\u0430 \u0446\u044f\u043b\u043e\u0441\u0442\u043d\u043e\u0442\u043e \u0432\u0438 \u0438\u0437\u0436\u0438\u0432\u044f\u0432\u0430\u043d\u0435 \u0441 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435\u0442\u043e.","intTextVersion":87334},{"strLang":"CS","strType":"txt","strText":"S va\u0161\u00edm souhlasem shroma\u017e\u010fujeme ur\u010dit\u00e9 informace t\u00fdkaj\u00edc\u00ed se va\u0161eho za\u0159\u00edzen\u00ed, IP adresy, pou\u017eit\u00ed a reklamn\u00edch identifik\u00e1tor\u016f. Pom\u00e1h\u00e1 n\u00e1m to zobrazovat v\u00e1m relevantn\u011bj\u0161\u00ed reklamy a zlep\u0161uje celkov\u00fd dojem z aplikace.","intTextVersion":87335},{"strLang":"DA","strType":"txt","strText":"Med dit samtykke indsamler vi visse oplysninger om din enhed, IP-adresse, brug og reklame-id&#39;er. Dette hj\u00e6lper os med at vise dig mere relevante annoncer og forbedrer din overordnede appoplevelse.","intTextVersion":87336},{"strLang":"EL","strType":"txt","strText":"\u039c\u03b5 \u03c4\u03b7 \u03c3\u03c5\u03b3\u03ba\u03b1\u03c4\u03ac\u03b8\u03b5\u03c3\u03ae \u03c3\u03b1\u03c2, \u03c3\u03c5\u03bb\u03bb\u03ad\u03b3\u03bf\u03c5\u03bc\u03b5 \u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03b5\u03c2 \u03c0\u03bb\u03b7\u03c1\u03bf\u03c6\u03bf\u03c1\u03af\u03b5\u03c2 \u03c3\u03c7\u03b5\u03c4\u03b9\u03ba\u03ac \u03bc\u03b5 \u03c4\u03b7 \u03c3\u03c5\u03c3\u03ba\u03b5\u03c5\u03ae \u03c3\u03b1\u03c2, \u03c4\u03b7 \u03b4\u03b9\u03b5\u03cd\u03b8\u03c5\u03bd\u03c3\u03b7 IP, \u03c4\u03b7 \u03c7\u03c1\u03ae\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03c4\u03b1 \u03b1\u03bd\u03b1\u03b3\u03bd\u03c9\u03c1\u03b9\u03c3\u03c4\u03b9\u03ba\u03ac \u03b4\u03b9\u03b1\u03c6\u03ae\u03bc\u03b9\u03c3\u03b7\u03c2. \u0391\u03c5\u03c4\u03cc \u03bc\u03b1\u03c2 \u03b2\u03bf\u03b7\u03b8\u03ac \u03bd\u03b1 \u03c3\u03b1\u03c2 \u03b4\u03b5\u03af\u03c7\u03bd\u03bf\u03c5\u03bc\u03b5 \u03c0\u03b9\u03bf \u03c3\u03c7\u03b5\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03b2\u03b5\u03bb\u03c4\u03b9\u03ce\u03bd\u03b5\u03b9 \u03c4\u03b7 \u03c3\u03c5\u03bd\u03bf\u03bb\u03b9\u03ba\u03ae \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae\u03c2 \u03c3\u03b1\u03c2.","intTextVersion":87337},{"strLang":"ET","strType":"txt","strText":"Teie n\u00f5usolekul kogume teatud teavet teie seadme, IP-aadressi, kasutuse ja reklaamiidentifikaatorite kohta. See aitab meil n\u00e4idata teile asjakohasemaid reklaame ja parandab teie \u00fcldist rakenduse kasutuskogemust.","intTextVersion":87338},{"strLang":"FI","strType":"txt","strText":"Suostumuksellasi ker\u00e4\u00e4mme tiettyj\u00e4 tietoja laitteestasi, IP-osoitteestasi, k\u00e4yt\u00f6st\u00e4si ja mainonnan tunnisteista. T\u00e4m\u00e4 auttaa meit\u00e4 n\u00e4ytt\u00e4m\u00e4\u00e4n sinulle osuvampia mainoksia ja parantaa yleist\u00e4 sovelluskokemustasi.","intTextVersion":87339},{"strLang":"GA","strType":"txt","strText":"Le do thoili\u00fa, bail\u00edmid faisn\u00e9is \u00e1irithe maidir le do ghl\u00e9as, seoladh IP, \u00fas\u00e1id agus aitheant\u00f3ir\u00ed f\u00f3gra\u00edochta. Cuid\u00edonn s\u00e9 seo linn f\u00f3gra\u00ed n\u00edos \u00e1bhartha a thaispe\u00e1int duit agus feabhsa\u00edonn s\u00e9 d\u2019eisp\u00e9ireas forioml\u00e1n ar aipeanna.","intTextVersion":87340},{"strLang":"HR","strType":"txt","strText":"Uz va\u0161 pristanak, prikupljamo odre\u0111ene podatke koji se odnose na va\u0161 ure\u0111aj, IP adresu, identifikatore upotrebe i ogla\u0161avanja. To nam poma\u017ee da vam prikazujemo relevantnije oglase i pobolj\u0161ava va\u0161e cjelokupno iskustvo aplikacije.","intTextVersion":87341},{"strLang":"HU","strType":"txt","strText":"Az \u00d6n beleegyez\u00e9s\u00e9vel bizonyos inform\u00e1ci\u00f3kat gy\u0171jt\u00fcnk az \u00d6n k\u00e9sz\u00fcl\u00e9k\u00e9r\u0151l, IP-c\u00edm\u00e9r\u0151l, haszn\u00e1lat\u00e1r\u00f3l \u00e9s hirdet\u00e9si azonos\u00edt\u00f3ir\u00f3l. Ez seg\u00edt sz\u00e1munkra relev\u00e1nsabb hirdet\u00e9seket megjelen\u00edteni, \u00e9s jav\u00edtja az \u00e1ltal\u00e1nos alkalmaz\u00e1s\u00e9lm\u00e9nyt.","intTextVersion":87342},{"strLang":"LT","strType":"txt","strText":"Jums sutikus, renkame tam tikr\u0105 informacij\u0105 apie j\u016bs\u0173 \u012frengin\u012f, IP adres\u0105, naudojim\u0105 ir reklamos identifikatorius. Tai padeda mums rodyti jums aktualesnius skelbimus ir pagerinti bendr\u0105 programos patirt\u012f.","intTextVersion":87343},{"strLang":"LV","strType":"txt","strText":"Ar j\u016bsu piekri\u0161anu m\u0113s apkopojam noteiktu inform\u0101ciju par j\u016bsu ier\u012bci, IP adresi, lietojumu un rekl\u0101mas identifikatoriem. Tas pal\u012bdz mums r\u0101d\u012bt jums atbilsto\u0161\u0101kas rekl\u0101mas un uzlabo visp\u0101r\u0113jo lietotnes pieredzi.","intTextVersion":87344},{"strLang":"MT","strType":"txt","strText":"Bil-kunsens tieg\u0127ek, a\u0127na ni\u0121bru \u010berta informazzjoni dwar it-tag\u0127mir tieg\u0127ek, l-indirizz IP, l-u\u017cu u l-identifikaturi tar-reklamar. Dan jg\u0127inna nuruk reklami aktar rilevanti u jtejjeb l-esperjenza \u0121enerali tal-app tieg\u0127ek.","intTextVersion":87345},{"strLang":"NL","strType":"txt","strText":"Met uw toestemming verzamelen wij bepaalde informatie over uw apparaat, IP-adres, gebruik en advertentie-identificatoren. Hierdoor kunnen we u relevantere advertenties laten zien en wordt uw algehele app-ervaring verbeterd.","intTextVersion":87346},{"strLang":"NO","strType":"txt","strText":"Med ditt samtykke samler vi inn visse opplysninger om enheten din, IP-adressen, bruken og annonseringsidentifikatorer. Dette hjelper oss med \u00e5 vise deg mer relevante annonser og forbedrer den generelle appopplevelsen din.","intTextVersion":87347},{"strLang":"PL","strType":"txt","strText":"Za Twoj\u0105 zgod\u0105 zbieramy okre\u015blone informacje dotycz\u0105ce Twojego urz\u0105dzenia, adresu IP, identyfikator\u00f3w u\u017cytkowania i reklam. Pomaga nam to wy\u015bwietla\u0107 trafniejsze reklamy i poprawia og\u00f3ln\u0105 wygod\u0119 korzystania z aplikacji.","intTextVersion":87348},{"strLang":"PT","strType":"txt","strText":"Com o seu consentimento, coletamos certas informa\u00e7\u00f5es relativas ao seu dispositivo, endere\u00e7o IP, uso e identificadores de publicidade. Isso nos ajuda a mostrar an\u00fancios mais relevantes e a melhorar sua experi\u00eancia geral no aplicativo.","intTextVersion":87349},{"strLang":"RO","strType":"txt","strText":"Cu acordul dvs., colect\u0103m anumite informa\u021bii referitoare la dispozitivul dvs., adresa IP, utilizarea \u0219i identificatorii de publicitate. Acest lucru ne ajut\u0103 s\u0103 v\u0103 ar\u0103t\u0103m anun\u021buri mai relevante \u0219i s\u0103 v\u0103 \u00eembun\u0103t\u0103\u021bim experien\u021ba general\u0103 \u00een aplica\u021bie.","intTextVersion":87350},{"strLang":"SK","strType":"txt","strText":"S va\u0161\u00edm s\u00fahlasom zhroma\u017e\u010fujeme ur\u010dit\u00e9 inform\u00e1cie t\u00fdkaj\u00face sa v\u00e1\u0161ho zariadenia, IP adresy, pou\u017e\u00edvania a reklamn\u00fdch identifik\u00e1torov. Pom\u00e1ha n\u00e1m to zobrazova\u0165 v\u00e1m relevantnej\u0161ie reklamy a zlep\u0161uje to celkov\u00fd dojem z aplik\u00e1cie.","intTextVersion":87351},{"strLang":"SL","strType":"txt","strText":"Z va\u0161im soglasjem zbiramo dolo\u010dene podatke v zvezi z va\u0161o napravo, naslovom IP, uporabo in ogla\u0161evalskimi identifikatorji. To nam pomaga, da vam prikazujemo ustreznej\u0161e oglase in izbolj\u0161a va\u0161o splo\u0161no izku\u0161njo aplikacije.","intTextVersion":87352},{"strLang":"RU","strType":"txt","strText":"\u0421 \u0432\u0430\u0448\u0435\u0433\u043e \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u044f \u043c\u044b \u0441\u043e\u0431\u0438\u0440\u0430\u0435\u043c \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u043d\u0443\u044e \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e, \u043a\u0430\u0441\u0430\u044e\u0449\u0443\u044e\u0441\u044f \u0432\u0430\u0448\u0435\u0433\u043e \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430, IP-\u0430\u0434\u0440\u0435\u0441\u0430, \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u043e\u0432 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u0438 \u0440\u0435\u043a\u043b\u0430\u043c\u043d\u044b\u0445 \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u043e\u0432. \u042d\u0442\u043e \u043f\u043e\u043c\u043e\u0433\u0430\u0435\u0442 \u043d\u0430\u043c \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u0432\u0430\u043c \u0431\u043e\u043b\u0435\u0435 \u0440\u0435\u043b\u0435\u0432\u0430\u043d\u0442\u043d\u0443\u044e \u0440\u0435\u043a\u043b\u0430\u043c\u0443 \u0438 \u0443\u043b\u0443\u0447\u0448\u0430\u0435\u0442 \u043e\u0431\u0449\u0435\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u0435 \u043e\u0442 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f.","intTextVersion":87353},{"strLang":"UK","strType":"txt","strText":"\u0417 \u0432\u0430\u0448\u043e\u0457 \u0437\u0433\u043e\u0434\u0438 \u043c\u0438 \u0437\u0431\u0438\u0440\u0430\u0454\u043c\u043e \u043f\u0435\u0432\u043d\u0443 \u0456\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0456\u044e \u043f\u0440\u043e \u0432\u0430\u0448 \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439, IP-\u0430\u0434\u0440\u0435\u0441\u0443, \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0442\u0430 \u0440\u0435\u043a\u043b\u0430\u043c\u043d\u0456 \u0456\u0434\u0435\u043d\u0442\u0438\u0444\u0456\u043a\u0430\u0442\u043e\u0440\u0438. \u0426\u0435 \u0434\u043e\u043f\u043e\u043c\u0430\u0433\u0430\u0454 \u043d\u0430\u043c \u043f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u0432\u0430\u043c \u0440\u0435\u043b\u0435\u0432\u0430\u043d\u0442\u043d\u0456\u0448\u0443 \u0440\u0435\u043a\u043b\u0430\u043c\u0443 \u0442\u0430 \u043f\u043e\u043a\u0440\u0430\u0449\u0443\u0454 \u0437\u0430\u0433\u0430\u043b\u044c\u043d\u0443 \u0432\u0437\u0430\u0454\u043c\u043e\u0434\u0456\u044e \u0437 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043e\u044e.","intTextVersion":87354},{"strLang":"TR","strType":"txt","strText":"\u0130zniniz do\u011frultusunda cihaz\u0131n\u0131z, IP adresiniz, kullan\u0131m ve reklam tan\u0131mlay\u0131c\u0131lar\u0131n\u0131zla ilgili belirli bilgileri topluyoruz. Bu, size daha alakal\u0131 reklamlar g\u00f6stermemize yard\u0131mc\u0131 olur ve genel uygulama deneyiminizi geli\u015ftirir.","intTextVersion":87355},{"strLang":"ZH","strType":"txt","strText":"\u7ecf\u60a8\u540c\u610f\uff0c\u6211\u4eec\u4f1a\u6536\u96c6\u6709\u5173\u60a8\u7684\u8bbe\u5907\u3001IP \u5730\u5740\u3001\u4f7f\u7528\u60c5\u51b5\u548c\u5e7f\u544a\u6807\u8bc6\u7b26\u7684\u67d0\u4e9b\u4fe1\u606f\u3002\u8fd9\u6709\u52a9\u4e8e\u6211\u4eec\u5411\u60a8\u5c55\u793a\u66f4\u76f8\u5173\u7684\u5e7f\u544a\u5e76\u6539\u5584\u60a8\u7684\u6574\u4f53\u5e94\u7528\u4f53\u9a8c\u3002","intTextVersion":87356},{"strLang":"SR","strType":"txt","strText":"\u0423\u0437 \u0432\u0430\u0448\u0443 \u0441\u0430\u0433\u043b\u0430\u0441\u043d\u043e\u0441\u0442, \u043f\u0440\u0438\u043a\u0443\u043f\u0459\u0430\u043c\u043e \u043e\u0434\u0440\u0435\u0452\u0435\u043d\u0435 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0458\u0435 \u0443 \u0432\u0435\u0437\u0438 \u0441\u0430 \u0432\u0430\u0448\u0438\u043c \u0443\u0440\u0435\u0452\u0430\u0458\u0435\u043c, \u0418\u041f \u0430\u0434\u0440\u0435\u0441\u043e\u043c, \u0443\u043f\u043e\u0442\u0440\u0435\u0431\u043e\u043c \u0438 \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u0438\u043c\u0430 \u0437\u0430 \u043e\u0433\u043b\u0430\u0448\u0430\u0432\u0430\u045a\u0435. \u041e\u0432\u043e \u043d\u0430\u043c \u043f\u043e\u043c\u0430\u0436\u0435 \u0434\u0430 \u0432\u0430\u043c \u043f\u0440\u0438\u043a\u0430\u0437\u0443\u0458\u0435\u043c\u043e \u0440\u0435\u043b\u0435\u0432\u0430\u043d\u0442\u043d\u0438\u0458\u0435 \u043e\u0433\u043b\u0430\u0441\u0435 \u0438 \u043f\u043e\u0431\u043e\u0459\u0448\u0430\u0432\u0430\u043c\u043e \u0446\u0435\u043b\u043e\u043a\u0443\u043f\u043d\u043e \u0438\u0441\u043a\u0443\u0441\u0442\u0432\u043e \u0430\u043f\u043b\u0438\u043a\u0430\u0446\u0438\u0458\u0435.","intTextVersion":87357},{"strLang":"AR","strType":"txt","strText":"\u0628\u0645\u0648\u0627\u0641\u0642\u062a\u0643\u060c \u0646\u0642\u0648\u0645 \u0628\u062c\u0645\u0639 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0645\u0639\u064a\u0646\u0629 \u062a\u062a\u0639\u0644\u0642 \u0628\u062c\u0647\u0627\u0632\u0643 \u0648\u0639\u0646\u0648\u0627\u0646 IP \u0648\u0627\u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0648\u0645\u0639\u0631\u0641\u0627\u062a \u0627\u0644\u0625\u0639\u0644\u0627\u0646\u0627\u062a. \u0648\u0647\u0630\u0627 \u064a\u0633\u0627\u0639\u062f\u0646\u0627 \u0639\u0644\u0649 \u0639\u0631\u0636 \u0627\u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0625\u0639\u0644\u0627\u0646\u0627\u062a \u0630\u0627\u062a \u0627\u0644\u0635\u0644\u0629 \u0648\u062a\u062d\u0633\u064a\u0646 \u062a\u062c\u0631\u0628\u0629 \u062a\u0637\u0628\u064a\u0642\u0643 \u0628\u0634\u0643\u0644 \u0639\u0627\u0645.","intTextVersion":87358},{"strLang":"BS","strType":"txt","strText":"Uz va\u0161 pristanak, prikupljamo odre\u0111ene informacije u vezi s va\u0161im ure\u0111ajem, IP adresom, upotrebom i identifikatorima ogla\u0161avanja. Ovo nam poma\u017ee da vam prikazujemo relevantnije oglase i pobolj\u0161avamo va\u0161e cjelokupno iskustvo aplikacije.","intTextVersion":87359},{"strLang":"DE","strType":"btn_custom","strText":"Erweitert","intTextVersion":134020},{"strLang":"EN","strType":"btn_custom","strText":"Advanced","intTextVersion":134021},{"strLang":"ES","strType":"btn_custom","strText":"Avanzado","intTextVersion":134022},{"strLang":"FR","strType":"btn_custom","strText":"Avanc\u00e9","intTextVersion":134023},{"strLang":"IT","strType":"btn_custom","strText":"Avanzato","intTextVersion":1340